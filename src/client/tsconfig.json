{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ESNext", "dom", "dom.iterable"],

    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "esnext",
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "references": [{ "path": "./tsconfig.node.json" }],
  "exclude": ["./vite.config.ts"]
}
